{
  "manifest_version": 3,
  "name": "Quick Recorder",
  "version": "0.3.1",
  "description": "One-click screen + camera + mic recording with floating camera overlay",
  "permissions": [
    "offscreen",
    "scripting",
    "tabs",
    "storage",
    "downloads",
    "activeTab",
    "notifications",
    "tabCapture",
    "contextMenus",
    "unlimitedStorage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "permissions.html",
        "camera.html",
        "camera.js",
        "editor.html",
        "editor.css",
        "editor.js",
        "lib/db.js",
        "lib/ffmpeg/ffmpeg.js",
        "lib/ffmpeg/814.ffmpeg.js",
        "lib/ffmpeg/ffmpeg-core.js",
        "lib/ffmpeg/ffmpeg-core.wasm",
        "icons/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Click to start / stop recording",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
